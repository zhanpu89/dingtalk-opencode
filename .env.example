# ---- 钉钉企业内部应用机器人（Stream 模式）----
# 在钉钉开放平台 (https://open-dev.dingtalk.com) 创建企业内部应用:
#   1. 应用开发 → 企业内部应用 → 创建应用
#   2. 应用功能 → 机器人 → 启用，消息接收模式选择 Stream
#   3. 从应用详情获取 AppKey / AppSecret
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_BOT_NAME=OpenCode

# ---- opencode ----
OPENCODE_SERVER_URL=http://localhost:4096
OPENCODE_SERVER_PASSWORD=

# opencode API 请求超时（毫秒）
REQUEST_TIMEOUT_MS=1800000

# 每个 Session 最大消息数（达到后自动轮换新会话，0=不限制）
# 避免上下文过长导致响应变慢或超时
MAX_MESSAGES_PER_SESSION=10

# 日志级别: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# 数据目录（session 映射文件等）
DATA_DIR=data

# ---- 多项目切换 ----
PROJECTS_CONFIG_PATH=projects.json
ALLOWED_PROJECT_ROOTS=/root/project
PROJECT_SERVER_PORT_START=4100
PROJECT_SERVER_HOSTNAME=127.0.0.1
PROJECT_SERVER_IDLE_MS=7200000
PROJECT_SWITCH_REQUIRED=false
