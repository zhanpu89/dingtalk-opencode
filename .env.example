# ---- 钉钉企业内部应用机器人（Stream 模式）----
# 在钉钉开放平台 (https://open-dev.dingtalk.com) 创建企业内部应用:
#   1. 应用开发 → 企业内部应用 → 创建应用
#   2. 应用功能 → 机器人 → 启用，消息接收模式选择 Stream
#   3. 从应用详情获取 AppKey / AppSecret
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_BOT_NAME=OpenCode

# ---- opencode ----
OPENCODE_SERVER_URL=http://localhost:4096
OPENCODE_SERVER_PASSWORD=

# opencode API 请求超时（毫秒）
REQUEST_TIMEOUT_MS=1800000

# 日志级别: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# 数据目录（session 映射文件等）
DATA_DIR=data
